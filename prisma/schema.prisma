generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STATION
}

enum Type {
  POLICE
  FIRE
}

model Admin {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(ADMIN)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  stations  Station[]
}

model Station {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  rank        String
  stationName String
  role        Role     @default(STATION)
  type        Type
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  admin       Admin?   @relation(fields: [adminId], references: [id])
  adminId     String

  duty   Duty[]
  staffs Staff[]
}

enum Status {
  AVAILABLE
  LEAVE
  DUTY
}

enum Condition {
  DRUNK
  BLACKLISTED
  DISABLED
  NORMAL
}

model Staff {
  id           String    @id @default(uuid())
  name         String
  pnoNo        String    @unique
  rank         String
  mobileNumber String
  status       Status    @default(AVAILABLE)
  capablity    Int?
  condition    Condition @default(NORMAL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lastDutyId String?
  stationId  String
  station    Station? @relation(fields: [stationId], references: [id])

  // Relations
  leaves      Leave[]
  assignments DutyAssign[]
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Duty {
  id       String     @id @default(uuid())
  dutyName String
  dutyType Difficulty
  location String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments DutyAssign[]
  station     Station?     @relation(fields: [stationId], references: [id])
  stationId   String?
}

model DutyAssign {
  id String @id @default(uuid())

  staffId String
  dutyId  String

  reportingTime DateTime
  relievingTime DateTime?
  assignedBy    String

  staff Staff @relation(fields: [staffId], references: [id])
  duty  Duty  @relation(fields: [dutyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([staffId])
  @@index([dutyId])
}

model Leave {
  id         String    @id @default(uuid())
  leaveType  String
  fromDate   DateTime
  toDate     DateTime?
  approvedBy String

  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
